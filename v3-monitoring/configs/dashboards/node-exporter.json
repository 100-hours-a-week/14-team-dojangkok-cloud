        {
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|docker.*|br-.*\",instance=~\"$instance\"}[5m])",
          "legendFormat": "{{instance}} - {{device}}",
          "refId": "A"
