{
  "uid": "alb",
  "title": "ALB",
  "description": "Application Load Balancer monitoring - request counts, response times, HTTP status codes, and target group health",
  "tags": [
    "alb",
    "cloudwatch"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "alb",
        "label": "ALB",
        "type": "query",
        "datasource": {
          "type": "cloudwatch",
          "uid": "cloudwatch"
        },
        "query": "dimension_values(ap-northeast-2, AWS/ApplicationELB, ActiveConnectionCount, LoadBalancer)",
        "definition": "dimension_values(ap-northeast-2, AWS/ApplicationELB, ActiveConnectionCount, LoadBalancer)",
        "refresh": 1,
        "regex": "/(?:dev|prod)-dojangkok/",
        "includeAll": false,
        "multi": false,
        "sort": 1
      },
      {
        "name": "tg",
        "label": "Target Group",
        "type": "query",
        "datasource": {
          "type": "cloudwatch",
          "uid": "cloudwatch"
        },
        "query": "dimension_values(ap-northeast-2, AWS/ApplicationELB, HealthyHostCount, TargetGroup, {\"LoadBalancer\": \"$alb\"})",
        "definition": "dimension_values(ap-northeast-2, AWS/ApplicationELB, HealthyHostCount, TargetGroup, {\"LoadBalancer\": \"$alb\"})",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "sort": 1
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
