          "statistic": "Average",
          "label": "",
          "metricQueryType": 0,
          "metricEditorMode": 0
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
