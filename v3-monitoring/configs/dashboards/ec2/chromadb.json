{
  "uid": "chromadb",
  "title": "ChromaDB",
  "tags": ["chromadb", "ec2", "docker"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "refresh": "15s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "15s", "30s", "1m", "5m"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h"]
  },
  "templating": { "list": [] },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "links": [],
  "panels": [
    {
      "type": "row",
      "title": "System Info",
      "collapsed": false,
      "id": 1,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "type": "stat",
      "title": "CPU Cores",
      "id": 2,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "count(node_cpu_seconds_total{mode=\"idle\",instance=\"dev-dojangkok-v3-chromadb\"})",
          "legendFormat": "cores",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Total Memory",
      "id": 3,
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes{instance=\"dev-dojangkok-v3-chromadb\"}",
          "legendFormat": "memory",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Root Disk Size",
      "id": 4,
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "node_filesystem_size_bytes{mountpoint=\"/\",instance=\"dev-dojangkok-v3-chromadb\"}",
          "legendFormat": "disk",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Uptime",
      "id": 5,
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "node_time_seconds{instance=\"dev-dojangkok-v3-chromadb\"} - node_boot_time_seconds{instance=\"dev-dojangkok-v3-chromadb\"}",
          "legendFormat": "uptime",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 3600 },
              { "color": "green", "value": 86400 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "type": "row",
      "title": "CPU",
      "collapsed": false,
      "id": 10,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "CPU Usage %",
      "id": 11,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\",instance=\"dev-dojangkok-v3-chromadb\"}[5m])) * 100)",
          "legendFormat": "CPU Usage",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": true,
            "axisCenteredZero": false,
            "axisLabel": "",
            "scaleDistribution": { "type": "linear" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "type": "timeseries",
      "title": "Load Average",
      "id": 12,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "node_load1{instance=\"dev-dojangkok-v3-chromadb\"}",
          "legendFormat": "1m",
          "refId": "A"
        },
        {
          "expr": "node_load5{instance=\"dev-dojangkok-v3-chromadb\"}",
          "legendFormat": "5m",
          "refId": "B"
        },
        {
          "expr": "node_load15{instance=\"dev-dojangkok-v3-chromadb\"}",
          "legendFormat": "15m",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "never",
            "spanNulls": true,
            "axisCenteredZero": false,
            "axisLabel": "",
            "scaleDistribution": { "type": "linear" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "type": "row",
      "title": "Memory",
      "collapsed": false,
      "id": 20,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Memory Usage",
      "id": 21,
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes{instance=\"dev-dojangkok-v3-chromadb\"} - node_memory_MemAvailable_bytes{instance=\"dev-dojangkok-v3-chromadb\"}",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "expr": "node_memory_MemAvailable_bytes{instance=\"dev-dojangkok-v3-chromadb\"}",
          "legendFormat": "Available",
          "refId": "B"
        },
        {
          "expr": "node_memory_Cached_bytes{instance=\"dev-dojangkok-v3-chromadb\"}",
          "legendFormat": "Cached",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 60,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "mode": "normal", "group": "A" },
            "axisCenteredZero": false,
            "axisLabel": "",
            "scaleDistribution": { "type": "linear" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Used" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Available" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Cached" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "type": "gauge",
      "title": "Memory Usage %",
      "id": 22,
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes{instance=\"dev-dojangkok-v3-chromadb\"} / node_memory_MemTotal_bytes{instance=\"dev-dojangkok-v3-chromadb\"}) * 100",
          "legendFormat": "Memory %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "type": "row",
      "title": "Disk",
      "collapsed": false,
      "id": 30,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Disk Usage %",
      "id": 31,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\",instance=\"dev-dojangkok-v3-chromadb\"} / node_filesystem_size_bytes{mountpoint=\"/\",instance=\"dev-dojangkok-v3-chromadb\"}) * 100",
          "legendFormat": "/ (root)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": true,
            "axisCenteredZero": false,
            "axisLabel": "",
            "scaleDistribution": { "type": "linear" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "orange", "value": 85 },
              { "color": "red", "value": 95 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "lastNotNull"] }
      }
    },
    {
      "type": "timeseries",
      "title": "Disk I/O",
      "id": 32,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total{instance=\"dev-dojangkok-v3-chromadb\"}[5m])",
          "legendFormat": "Read - {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_disk_written_bytes_total{instance=\"dev-dojangkok-v3-chromadb\"}[5m])",
          "legendFormat": "Write - {{device}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "none",
            "showPoints": "never",
            "spanNulls": true,
            "axisCenteredZero": false,
            "axisLabel": "",
            "scaleDistribution": { "type": "linear" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "/Read.*/" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/Write.*/" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "type": "row",
      "title": "Network",
      "collapsed": false,
      "id": 40,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Network Traffic",
      "id": 41,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|veth.*|docker.*|br-.*\",instance=\"dev-dojangkok-v3-chromadb\"}[5m])",
          "legendFormat": "Receive - {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|docker.*|br-.*\",instance=\"dev-dojangkok-v3-chromadb\"}[5m])",
          "legendFormat": "Transmit - {{device}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": true,
            "axisCenteredZero": false,
            "axisLabel": "",
            "scaleDistribution": { "type": "linear" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "/Receive.*/" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/Transmit.*/" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "type": "timeseries",
      "title": "Network Errors",
      "id": 42,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(node_network_receive_errs_total{device!~\"lo|veth.*|docker.*|br-.*\",instance=\"dev-dojangkok-v3-chromadb\"}[5m])",
          "legendFormat": "Receive Errors - {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_errs_total{device!~\"lo|veth.*|docker.*|br-.*\",instance=\"dev-dojangkok-v3-chromadb\"}[5m])",
          "legendFormat": "Transmit Errors - {{device}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "none",
            "showPoints": "never",
            "spanNulls": true,
            "axisCenteredZero": false,
            "axisLabel": "",
            "scaleDistribution": { "type": "linear" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "type": "row",
      "title": "Docker Logs",
      "collapsed": false,
      "id": 50,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 },
      "panels": []
    },
    {
      "type": "logs",
      "title": "ChromaDB Logs",
      "id": 51,
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 42 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{instance=\"dev-dojangkok-v3-chromadb\", job=\"docker\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "type": "row",
      "title": "Error Logs",
      "collapsed": false,
      "id": 60,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 54 },
      "panels": []
    },
    {
      "type": "logs",
      "title": "ChromaDB Error Logs",
      "id": 61,
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 55 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{instance=\"dev-dojangkok-v3-chromadb\", job=\"docker\"} |~ \"(?i)error|exception|fatal|traceback\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}