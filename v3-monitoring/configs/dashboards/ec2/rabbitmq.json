        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "label_replace(rabbitmq_queue_messages_ready{instance=~\"$instance\",queue=~\"$queue\"}, \"__name__\", \"ready\", \"\", \"\")",
          "legendFormat": "",
