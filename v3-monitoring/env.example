# =============================================================================
# V3 Monitoring Server - Environment Variables
# =============================================================================
# 1. EC2 인스턴스를 수동 생성 (t4g.medium, Ubuntu ARM64, Docker 설치, EIP 할당)
# 2. 아래 값을 채운 뒤 스크립트 실행:
#      ./00_preflight.sh → ./01_create_s3.sh → ./02_install_stack.sh
#      → ./03_install_alloy.sh → ./04_verify.sh
# =============================================================================

# AWS
AWS_PROFILE=tf
AWS_REGION=ap-northeast-2

# VPC
VPC_ID=vpc-08b809f7d33f0f9b1
VPC_CIDR=10.0.0.0/18

# Naming
NAME_PREFIX=dev-dojangkok-v3
ENV_NAME=dev

# --- Monitor Server (수동 생성 후 기입) ---
MONITOR_INSTANCE_ID=
MONITOR_PUBLIC_IP=                    # EIP
MONITOR_PRIVATE_IP=
MONITOR_IAM_ROLE=                     # EC2에 연결된 IAM Role 이름

# S3 (monitoring data — Loki/Tempo/Thanos)
S3_MONITORING_BUCKET=dev-dojangkok-v3-monitoring

# S3 (Alloy config 배포용 — 기존 버킷 재사용)
S3_CONFIG_BUCKET=ktb-team14-dojangkok-deploy
S3_CONFIG_PREFIX=alloy-configs-v3

# Security Group Sources
ADMIN_IP=211.244.225.211/32
GCP_NAT_IP=34.22.64.174/32
# K8S_NAT_IPS=x.x.x.x/32,y.y.y.y/32,z.z.z.z/32

# Grafana
GRAFANA_ADMIN_PASSWORD=

# BE/FE (ASG + Launch Template)
BE_LAUNCH_TEMPLATE_ID=lt-0c11f8cb1def2f374
FE_LAUNCH_TEMPLATE_ID=lt-01e05ca97d8949a34
BE_ASG_NAME=CodeDeploy_dev-dojangkok-v2-be-dg_d-UYN5JTU2H
FE_ASG_NAME=CodeDeploy_dev-dojangkok-v2-fe-dg_d-OJ4K2VU2H

# Fixed Instances (for SSM Alloy deploy)
TARGET_MYSQL_INSTANCE_ID=i-0ecc324a556ea03d6
TARGET_REDIS_INSTANCE_ID=i-04ca294eab052c26d
TARGET_MQ_INSTANCE_ID=i-0681d5ba66ddab079
