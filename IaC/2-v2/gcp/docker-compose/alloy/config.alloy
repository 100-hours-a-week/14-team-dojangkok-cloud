// Grafana Alloy — GCP V2 모니터링 (Terraform templatefile)
// VM: ${hostname} | Service: ${service_name}

// --- 1. Prometheus Remote Write ---
prometheus.remote_write "default" {
  endpoint {
    url = "${prometheus_url}"
  }
}

// --- 2. Loki Write ---
loki.write "default" {
  endpoint {
    url = "${loki_url}"
  }
}

// --- 3. Relabel: instance 라벨 ---
prometheus.relabel "instance_label" {
  forward_to = [prometheus.remote_write.default.receiver]

  rule {
    target_label = "instance"
    replacement  = "${hostname}"
  }

  rule {
    source_labels = ["job"]
    regex         = "integrations/unix"
    target_label  = "job"
    replacement   = "node"
  }
}

// --- 4. Node Exporter (Alloy 내장) ---
prometheus.exporter.unix "node" {
  set_collectors = ["cpu", "diskstats", "filesystem", "loadavg", "meminfo", "netdev", "uname"]
}

prometheus.scrape "node" {
  targets         = prometheus.exporter.unix.node.targets
  forward_to      = [prometheus.relabel.instance_label.receiver]
  scrape_interval = "15s"
  job_name        = "node"
}

%{ if enable_dcgm_exporter ~}
// --- 5. DCGM GPU Exporter (vLLM only) ---
prometheus.scrape "dcgm" {
  targets         = [{ __address__ = "localhost:9400" }]
  forward_to      = [prometheus.relabel.instance_label.receiver]
  scrape_interval = "15s"
}
%{ endif ~}

// --- 6. Docker 컨테이너 로그 ---
discovery.docker "containers" {
  host = "unix:///var/run/docker.sock"
}

discovery.relabel "docker_labels" {
  targets = discovery.docker.containers.targets

  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/(.*)"
    target_label  = "container"
  }
}

loki.source.docker "containers" {
  host       = "unix:///var/run/docker.sock"
  targets    = discovery.relabel.docker_labels.output
  forward_to = [loki.write.default.receiver]

  labels = {
    job     = "docker",
    host    = "${hostname}",
    service = "${service_name}",
  }
}

// --- 7. OTLP 트레이스 → Tempo ---
otelcol.receiver.otlp "default" {
  grpc {
    endpoint = "0.0.0.0:4317"
  }
  http {
    endpoint = "0.0.0.0:4318"
  }

  output {
    traces = [otelcol.exporter.otlp.tempo.input]
  }
}

otelcol.exporter.otlp "tempo" {
  client {
    endpoint = "${tempo_endpoint}"

    tls {
      insecure = true
    }
  }
}
