# =============================================================================
# V2 Monitoring Server - Environment Variables
# =============================================================================
# Copy to .env and fill in all blank values before running scripts.
#   cp env.example .env
# =============================================================================

# AWS
AWS_PROFILE=tf
AWS_REGION=ap-northeast-2

# VPC / Subnet
VPC_ID=vpc-08b809f7d33f0f9b1
SUBNET_ID=subnet-0d0295b4a08a503a9   # dev-dojangkok-v2-public-2a

# Instance (Monitor Server)
INSTANCE_TYPE=t4g.large
VOLUME_SIZE=50

# AMI (Ubuntu 22.04 ARM64, Docker + Alloy pre-installed)
AMI_ID=ami-00bdfd4994555f74f

# Naming
NAME_PREFIX=dev-dojangkok-v2-monitor

# S3 (config distribution)
S3_BUCKET=ktb-team14-dojangkok-deploy
S3_PREFIX=alloy-configs

# Security Group Sources
ADMIN_IP=211.244.225.211/32
DEV_VPC_CIDR=10.0.0.0/18
GCP_NAT_IP=34.64.221.18/32

# Grafana
GRAFANA_ADMIN_PASSWORD=admin12345!

# BE/FE (ASG + Launch Template)
BE_LAUNCH_TEMPLATE_ID=lt-0c11f8cb1def2f374
FE_LAUNCH_TEMPLATE_ID=lt-01e05ca97d8949a34
BE_ASG_NAME=CodeDeploy_dev-dojangkok-v2-be-dg_d-UYN5JTU2H
FE_ASG_NAME=CodeDeploy_dev-dojangkok-v2-fe-dg_d-OJ4K2VU2H

# Fixed Instances
TARGET_MYSQL_IP=10.0.12.180
TARGET_REDIS_IP=10.0.13.153
TARGET_MQ_IP=10.0.14.159
TARGET_MYSQL_INSTANCE_ID=i-0ecc324a556ea03d6
TARGET_REDIS_INSTANCE_ID=i-04ca294eab052c26d
TARGET_MQ_INSTANCE_ID=i-0681d5ba66ddab079

# Monitor Server (populated by 01_create_monitor.sh)
MONITOR_INSTANCE_ID=
MONITOR_PUBLIC_IP=
MONITOR_PRIVATE_IP=
